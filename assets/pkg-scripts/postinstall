#!/bin/bash
# PKGインストール後にGatekeeper問題を修正するスクリプト
# 「破損しているか不完全」エラーを防止する
# 注意: codesign --sign - はElectron v40の内部整合性チェックを壊すため使用禁止

APP_PATH="/Applications/Obsidian Optimizer.app"

if [ -d "$APP_PATH" ]; then
    # dot_cleanでリソースフォーク（._ファイル）を除去
    dot_clean "$APP_PATH" 2>/dev/null || true

    # quarantine / provenance属性を全て除去（これだけでGatekeeperを通過できる）
    xattr -cr "$APP_PATH" 2>/dev/null || true

    # com.apple.provenanceを個別に明示除去（xattr -crで取れないことがある）
    find "$APP_PATH" -exec xattr -d com.apple.provenance {} 2>/dev/null \; || true
    find "$APP_PATH" -exec xattr -d com.apple.quarantine {} 2>/dev/null \; || true

    # 権限を修正
    chmod -R a+rX "$APP_PATH" 2>/dev/null || true
    chmod -R 755 "$APP_PATH/Contents/MacOS" 2>/dev/null || true

    echo "Obsidian Optimizer: postinstall completed successfully"
fi

exit 0
